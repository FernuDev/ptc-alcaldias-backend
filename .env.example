# PostgreSQL
DATABASE_URL=postgresql+asyncpg://ptc:ptc_secret@localhost:5432/ptc_alcaldias

# JWT
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# App
APP_ENV=development

# ── Agente Institucional · Motor LLM ──
# Proveedor activo: deepseek (por defecto) | anthropic | fake (tests)
LLM_PROVIDER=deepseek
# Pega aquí tu API key de DeepSeek. NO la subas a git.
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Para migrar a Claude: LLM_PROVIDER=anthropic y completa la key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1500

# ── Agente Institucional · RAG ──
VECTOR_DB_PATH=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2
KNOWLEDGE_PATH=./data/seed/knowledge
